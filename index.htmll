<!DOCTYPE html>
<html>
<head>
    <title>FC Mobile 26 | GOAT Collection</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <style>
        body { 
            background-color: #0d1117; 
            color: white;
            margin: 0;
            padding: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
            font-family: 'Arial', sans-serif;
        }
        h1 { color: #fcc419; text-transform: uppercase; letter-spacing: 2px; text-shadow: 2px 2px 4px #000; }
        .card-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 25px;
            width: 100%;
            max-width: 1000px;
        }
        .player-card {
            background: linear-gradient(145deg, #1f2937, #111827);
            border: 2px solid #374151;
            border-radius: 20px;
            padding: 15px;
            text-align: center;
            box-shadow: 0px 10px 20px rgba(0,0,0,0.5);
            transition: transform 0.3s;
        }
        .player-card:hover { transform: scale(1.05); border-color: #fcc419; }
        .rating { font-size: 32px; font-weight: bold; color: #fcc419; margin: 5px 0; }
        .event-tag { font-size: 12px; font-weight: bold; text-transform: uppercase; background: #3b82f6; padding: 3px 8px; border-radius: 5px; }
        img { width: 100%; border-radius: 10px; margin: 10px 0; }
        .stats { display: flex; justify-content: space-around; font-size: 14px; background: rgba(0,0,0,0.3); padding: 10px; border-radius: 10px; }
    </style>
</head>
<body>

    <h1>FC Mobile 26 GOATs</h1>

    <div class="card-grid">
        <!-- Ronaldo Flashback -->
        <div class="player-card">
            <span class="event-tag">Flashback</span>
            <div class="rating">117</div>
            <h2>C. Ronaldo</h2>
            <img src="https://pbs.twimg.com" alt="Ronaldo Flashback">
            <div class="stats">
                <span>PAC: 115</span> <span>SHO: 120</span> <span>DRI: 110</span>
            </div>
        </div>

        <!-- Messi TOTY -->
        <div class="player-card" style="border-color: #fcc419;">
            <span class="event-tag" style="background: #fcc419; color: black;">TOTY Icon</span>
            <div class="rating">119</div>
            <h2>Lionel Messi</h2>
            <img src="https://pbs.twimg.com" alt="Messi TOTY">
            <div class="stats">
                <span>PAC: 112</span> <span>SHO: 118</span> <span>DRI: 124</span>
            </div>
        </div>

        <!-- Ronaldo Time Warp -->
        <div class="player-card">
            <span class="event-tag" style="background: #a855f7;">Time Warp</span>
            <div class="rating">90</div>
            <h2>C. Ronaldo</h2>
            <img src="https://images.unsplash.com" alt="Ronaldo Base">
            <div class="stats">
                <span>PAC: 76</span> <span>SHO: 88</span> <span>DRI: 80</span>
            </div>
        </div>

        <!-- Messi Time Warp -->
        <div class="player-card">
            <span class="event-tag" style="background: #a855f7;">Time Warp</span>
            <div class="rating">90</div>
            <h2>Lionel Messi</h2>
            <img src="https://images.unsplash.com" alt="Messi Base">
            <div class="stats">
                <span>PAC: 79</span> <span>SHO: 85</span> <span>DRI: 92</span>
            </div>
        </div>
    </div>

</body>
</html>
